{
  "name": "timestamp-workspace",
  "version": "0.1.0-alpha.3",
  "private": true,
  "description": "Timestamp workspace.",
  "license": "MIT",
  "author": "Jeff <galbraith64@gmail.com>",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules pnpm-lock.yaml packages/lib/node_modules packages/lib/dist packages/docs/node_modules packages/docs/dist packages/docs/.quasar",
    "build": "pnpm build:lib && pnpm build:docs",
    "build:lib": "pnpm --filter @timestamp-js/core build",
    "build:docs": "pnpm --filter @timestamp-js/docs build",
    "docs:build": "pnpm --filter @timestamp-js/docs build",
    "docs:dev": "pnpm --filter @timestamp-js/docs dev",
    "deep": "ncu --configFilePath . --packageFile '{package.json,packages/*/package.json}'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "pnpm --filter @timestamp-js/core test",
    "typecheck": "pnpm --filter @timestamp-js/core typecheck && pnpm --filter @timestamp-js/docs typecheck",
    "check:all": "pnpm verify",
    "verify": "pnpm verify:fast && pnpm verify:build",
    "verify:fast": "pnpm format:check && pnpm lint && pnpm test",
    "verify:build": "pnpm build && pnpm typecheck",
    "ci:publish": "pnpm --filter @timestamp-js/core publish --access public --publish-branch master",
    "ci:publish:alpha": "pnpm --filter @timestamp-js/core publish --access public --publish-branch master --tag alpha",
    "ci:publish:latest": "pnpm --filter @timestamp-js/core publish --access public --publish-branch master --tag latest",
    "ci:publish:beta": "pnpm --filter @timestamp-js/core publish --access public --publish-branch master --tag beta"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "npm-check-updates": "22.2.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.5.0"
  },
  "packageManager": "pnpm@11.5.2"
}
