{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 100,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.quasar/**",
    "**/dist/**",
    "**/coverage/**",
    "packages/docs/src/.q-press/**",
    "pnpm-lock.yaml"
  ]
}
