{
  "name": "@timestamp-js/docs",
  "version": "0.1.0-rc.2",
  "private": true,
  "description": "Q-Press documentation site for @timestamp-js/core.",
  "author": "Jeff <galbraith64@gmail.com>",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist .quasar node_modules",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit --pretty false",
    "api:review": "qpress api generate --root ../..",
    "api:generate": "qpress api generate --root ../.. --write-output",
    "api:check": "qpress api check --root ../..",
    "check:qpress": "qpress check",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "pnpm api:generate && pnpm run build:ssg",
    "build:spa": "quasar build",
    "build:ssg": "quasar prepare && quasar build && qpress ssg",
    "postinstall": "quasar prepare",
    "build:ssg:renderer": "quasar prepare && quasar build -m ssr",
    "prerender:ssg": "qpress ssg",
    "preview:ssg": "quasar serve dist/spa --history"
  },
  "dependencies": {
    "@quasar/extras": "2.0.1",
    "@timestamp-js/calendar-islamic": "workspace:*",
    "@timestamp-js/calendar-saka": "workspace:*",
    "@timestamp-js/core": "workspace:*",
    "pinia": "^3.0.4",
    "quasar": "^2.20.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@md-plugins/quasar-app-extension-q-press": "0.1.0-rc.18",
    "@md-plugins/search-ui": "0.1.0-rc.18",
    "@md-plugins/vite-examples-plugin": "0.1.0-rc.18",
    "@md-plugins/vite-md-plugin": "0.1.0-rc.18",
    "@md-plugins/vite-search-plugin": "0.1.0-rc.18",
    "@md-plugins/vite-ssg-plugin": "0.1.0-rc.18",
    "@quasar/app-vite": "3.0.0-rc.3",
    "@types/node": "^26.0.1",
    "@vue/server-renderer": "^3.5.39",
    "autoprefixer": "^10.5.2",
    "mermaid": "^11.16.0",
    "sass-embedded": "^1.100.0",
    "shiki": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-checker": "^0.14.4",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.3.0"
  },
  "productName": "Timestamp"
}
