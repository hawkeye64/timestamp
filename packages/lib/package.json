{
  "name": "@timestamp-js/core",
  "version": "0.1.0-rc.0",
  "description": "Framework-agnostic Timestamp utility.",
  "keywords": [
    "calendar",
    "date",
    "time",
    "timestamp",
    "typescript"
  ],
  "homepage": "https://github.com/hawkeye64/timestamp#readme",
  "bugs": {
    "url": "https://github.com/hawkeye64/timestamp/issues"
  },
  "license": "MIT",
  "author": "Jeff <galbraith64@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hawkeye64/timestamp.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "build": "tsc -p tsconfig.build.json",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:tz": "TZ=UTC vitest run test/timezoneMatrix.spec.ts && TZ=America/Edmonton vitest run test/timezoneMatrix.spec.ts && TZ=Asia/Kathmandu vitest run test/timezoneMatrix.spec.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.5.0"
  },
  "packageManager": "pnpm@11.5.3"
}
